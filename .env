# ─── Ani-Log Environment Configuration ───

# General
APP_NAME=Ani-Log
DEBUG=true
LOG_LEVEL=INFO

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ChromaDB
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION_CHARACTERS=ani_log_characters
CHROMA_COLLECTION_SCENES=ani_log_scenes
CHROMA_COLLECTION_ITEMS=ani_log_items

# YOLO-World
YOLO_MODEL=yolov8x-worldv2
YOLO_CONFIDENCE=0.35
YOLO_DEVICE=cuda:0

# CLIP
CLIP_MODEL=ViT-L/14
CLIP_DEVICE=cuda:0

# Tracking
TRACKER_MAX_AGE=30
TRACKER_MIN_HITS=3
TRACKER_IOU_THRESHOLD=0.3
REIDENTIFICATION_THRESHOLD=0.75

# Frame Sampling
CAPTURE_FPS=2
SCENE_CHANGE_THRESHOLD=0.4

# Ollama (Local LLM)
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b

# ZeroMQ IPC
ZMQ_CAPTURE_PORT=5555
ZMQ_RESULT_PORT=5556

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# SQLite (metadata store)
DATABASE_URL=sqlite:///./ani_log.db
